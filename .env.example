# 币安AI交易Agent环境变量配置
# 复制此文件为 .env 并填写实际值

# ============ 币安API配置 ============

# 币安API密钥（从币安官网获取）
# 注意：Testnet和Mainnet的API密钥不同
BINANCE_API_KEY=your_api_key_here

# 币安Secret密钥（从币安官网获取）
BINANCE_SECRET_KEY=your_secret_key_here

# 是否使用测试网 (true/false)
# 开发阶段建议使用测试网，避免资金风险
BINANCE_TESTNET=true

# ============ Telegram通知配置 ============

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID（接收通知的聊天ID）
TELEGRAM_CHAT_ID=your_chat_id_here

# ============ 日志配置 ============

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/agent.log

# ============ 系统配置 ============

# 交易模式: simulation, paper, live
TRADING_MODE=simulation

# 模拟交易初始资金 (USDT)
SIMULATION_INITIAL_CAPITAL=10000

# 数据存储格式: parquet, csv
DATA_STORAGE_FORMAT=parquet

# ============ 安全提示 ============
#
# ⚠️ 安全警告：
# 1. 此文件包含敏感信息，切勿提交到版本控制
# 2. 生产环境建议使用加密存储或密钥管理服务
# 3. 定期轮换API密钥
# 4. 为API密钥设置IP白名单和权限限制
#
# ⚠️ Git忽略配置：
# 确保 .gitignore 文件包含以下行：
#   .env
#   *.env.local
#   *.env.*.local
#
# ============ 测试网说明 ============
#
# 测试网使用步骤：
# 1. 访问 https://testnet.binance.vision/
# 2. 注册测试网账号
# 3. 获取测试网API密钥
# 4. 领取测试网USDT（用于模拟交易）
#
# 测试网限制：
# - 仅用于测试，不涉及真实资金
# - 数据可能与主网略有差异
# - 部分功能可能不可用
#
# ============ 主网切换说明 ============
#
# 切换到主网：
# 1. 将 BINANCE_TESTNET=false
# 2. 使用主网API密钥和Secret
# 3. 确保了解资金风险
# 4. 从小额资金开始测试
#
# 主网安全建议：
# 1. 使用独立的交易账户
# 2. 设置每日交易限额
# 3. 启用双因素认证
# 4. 定期检查账户活动
#