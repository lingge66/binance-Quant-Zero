
# 1. 币安合约测试网密钥 (必须是 Testnet Futures)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# 2. 全局穿甲代理 (给整个 Python 环境使用)如使用可打开，端口换成自己的。
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=http://127.0.0.1:7890
# TELEGRAM_PROXY=http://127.0.0.1:7890
# 如果你的代理是 SOCKS5
# TELEGRAM_PROXY=socks5://127.0.0.1:7890
TELEGRAM_CHAT_ID=电报ID

# 电报机器人密钥
TELEGRAM_BOT_TOKEN=

# 2. AI 大脑配置 (必填，用于解析自然语言和推演)
# 支持 OpenAI、DeepSeek、Gemini (需兼容 OpenAI API 格式)
AI_API_KEY="填入自己的模型API"

# 填写你所用模型的 Base URL。
# DeepSeek 示例: https://api.deepseek.com/v1
# Gemini 示例: https://generativelanguage.googleapis.com/v1beta/openai/
AI_BASE_URL="https://api.deepseek.com/v1"

# 填写对应的模型名称
AI_MODEL_NAME="deepseek-chat"

# ============ 安全提示 ============
#
# ⚠️ 安全警告：
# 1. 此文件包含敏感信息，切勿提交到版本控制
# 2. 生产环境建议使用加密存储或密钥管理服务
# 3. 定期轮换API密钥
# 4. 为API密钥设置IP白名单和权限限制
#
# ⚠️ Git忽略配置：
# 确保 .gitignore 文件包含以下行：
#   .env
#   *.env.local
#   *.env.*.local
#
# ============ 测试网说明 ============
#
# 测试网使用步骤：
# 1. 访问 https://demo.binance.com/en/my/settings/api-management
# 2. 注册测试网账号
# 3. 获取测试网API密钥
# 4. 领取测试网USDT（用于模拟交易）
#
# 测试网限制：
# - 仅用于测试，不涉及真实资金
# - 数据可能与主网略有差异
# - 部分功能可能不可用
#
